{
  "manager": "Timo's Scripts",
  "version": "1.0",
  "author": "Timodej",
  "scripts": [
    {
      "name": "Timos-Scripts",
      "file": "Timos-Scripts.js",
      "description": "De script manager zelf. Update om nieuwe functies en bugfixes te krijgen.",
      "version": "1.0",
      "isSelf": true,
      "settings": []
    },
    {
      "name": "Lockscreen-weer-datum",
      "file": "Lockscreen-weer-datum.js",
      "description": "Lockscreen widget die het weer toont op één regel. Temperatuur, weeremoji en regenvoorspelling.",
      "version": "1.0",
      "langFile": "timoLanguage-weer.json",
      "settingsFile": "Lockscreen-weer-datum-settings.json",
      "settings": [
        { "key": "language", "type": "language", "section": "Taal" },
        {
          "key": "openApp", "type": "app", "section": "Gedrag", "label": "labelOpenApp",
          "apps": [
            { "label": "Weeronline", "scheme": "weeronline" },
            { "label": "Buienradar", "scheme": "buienradar" },
            { "label": "Apple Weer", "scheme": "weather" },
            { "label": "Overig", "scheme": "custom" }
          ],
          "default": "weeronline"
        },
        {
          "key": "rainApi", "type": "choice", "section": "Regen", "label": "labelRainApi",
          "choices": [
            { "label": "Open-Meteo 🌍", "value": "openmeteo" },
            { "label": "Buienradar 🇳🇱", "value": "buienradar" },
            { "label": "Combinatie 🔀", "value": "combined" }
          ],
          "default": "openmeteo"
        },
        {
          "key": "rainDisplay", "type": "choice", "section": "Regen", "label": "labelRainDisplay",
          "choices": [
            { "label": "Wolkjes 🌧️🌧️🌧️", "value": "clouds" },
            { "label": "Millimeter 2.4mm", "value": "mm" }
          ],
          "default": "clouds"
        },
        {
          "key": "rainTime", "type": "choice", "section": "Regen", "label": "labelRainTime",
          "choices": [
            { "label": "Duur (45min / 1u+)", "value": "duration" },
            { "label": "Eindtijd (23:05)", "value": "endtime" }
          ],
          "default": "duration"
        },
        { "key": "regenDrempelKans", "type": "number", "section": "Regen", "label": "labelRegenDrempelKans", "default": 70, "min": 10, "max": 100 },
        { "key": "regenDrempelMm", "type": "decimal", "section": "Regen", "label": "labelRegenDrempelMm", "default": 0.2 },
        { "key": "regenMinimumMm", "type": "decimal", "section": "Regen", "label": "labelRegenMinimumMm", "default": 0.5 },
        { "key": "dichtbijUren", "type": "number", "section": "Regen", "label": "labelDichtbijUren", "default": 3, "min": 1, "max": 12 },
        { "key": "fontSize", "type": "number", "section": "Weergave", "label": "labelFontSize", "default": 10, "min": 8, "max": 16 }
      ]
    },
    {
      "name": "Lockscreen-upcoming-left",
      "file": "Lockscreen-upcoming-left.js",
      "description": "Lockscreen widget (links). Toont eerst openstaande reminders, daarna aankomende agenda-events aanvullend tot 6 regels.",
      "version": "1.0",
      "langFile": "timoLanguage-upcoming.json",
      "settingsFile": "Lockscreen-upcoming-left-settings.json",
      "settings": [
        { "key": "language", "type": "language", "section": "Taal" },
        {
          "key": "openApp", "type": "app", "section": "Gedrag", "label": "labelOpenApp",
          "apps": [
            { "label": "Reminders", "scheme": "x-apple-reminderkit" },
            { "label": "WeekCal", "scheme": "weekcal" },
            { "label": "Fantastical", "scheme": "fantastical2" },
            { "label": "Apple Agenda", "scheme": "calshow" },
            { "label": "Overig", "scheme": "custom" }
          ],
          "default": "x-apple-reminderkit"
        },
        { "key": "calendars", "type": "calendars", "section": "Agenda", "label": "labelCalendars" },
        { "key": "daysAhead", "type": "number", "section": "Agenda", "label": "labelDaysAhead", "default": 7, "min": 1, "max": 30 },
        { "key": "listItems", "type": "number", "section": "Weergave", "label": "labelListItems", "default": 6, "min": 1, "max": 10 },
        { "key": "fontSize", "type": "number", "section": "Weergave", "label": "labelFontSize", "default": 10, "min": 8, "max": 16 },
        { "key": "showEndTime", "type": "boolean", "section": "Weergave", "label": "labelShowEndTime", "default": false },
        {
          "key": "textStyle", "type": "choice", "section": "Weergave", "label": "labelTextStyle",
          "choices": [
            { "label": "Wit / Grijs", "value": "color" },
            { "label": "Bold / Normaal wit", "value": "bold" },
            { "label": "Groter / Kleiner", "value": "size" },
            { "label": "Bold wit / Lichtgrijs", "value": "boldcolor" }
          ],
          "default": "color"
        },
        {
          "key": "dateFormat", "type": "choice", "section": "Weergave", "label": "labelDateFormat",
          "choices": [
            { "label": "12-5", "value": "date" },
            { "label": "Ma (afgekort)", "value": "short" },
            { "label": "Maandag (volledig)", "value": "full" }
          ],
          "default": "date"
        },
        {
          "key": "alignment", "type": "choice", "section": "Weergave", "label": "labelAlignment",
          "choices": [
            { "label": "Links", "value": "left" },
            { "label": "Rechts", "value": "right" }
          ],
          "default": "left"
        }
      ]
    },
    {
      "name": "Lockscreen-upcoming-right",
      "file": "Lockscreen-upcoming-right.js",
      "description": "Lockscreen widget (rechts). Toont de eerstvolgende agenda-events die niet in de linker widget staan.",
      "version": "1.0",
      "langFile": "timoLanguage-upcoming.json",
      "settingsFile": "Lockscreen-upcoming-right-settings.json",
      "settings": [
        { "key": "language", "type": "language", "section": "Taal" },
        {
          "key": "openApp", "type": "app", "section": "Gedrag", "label": "labelOpenApp",
          "apps": [
            { "label": "WeekCal", "scheme": "weekcal" },
            { "label": "Fantastical", "scheme": "fantastical2" },
            { "label": "Apple Agenda", "scheme": "calshow" },
            { "label": "Reminders", "scheme": "x-apple-reminderkit" },
            { "label": "Overig", "scheme": "custom" }
          ],
          "default": "weekcal"
        },
        { "key": "calendars", "type": "calendars", "section": "Agenda", "label": "labelCalendars" },
        { "key": "daysAhead", "type": "number", "section": "Agenda", "label": "labelDaysAhead", "default": 7, "min": 1, "max": 30 },
        { "key": "listItems", "type": "number", "section": "Weergave", "label": "labelListItems", "default": 6, "min": 1, "max": 10 },
        { "key": "fontSize", "type": "number", "section": "Weergave", "label": "labelFontSize", "default": 10, "min": 8, "max": 16 },
        { "key": "showEndTime", "type": "boolean", "section": "Weergave", "label": "labelShowEndTime", "default": false },
        {
          "key": "textStyle", "type": "choice", "section": "Weergave", "label": "labelTextStyle",
          "choices": [
            { "label": "Wit / Grijs", "value": "color" },
            { "label": "Bold / Normaal wit", "value": "bold" },
            { "label": "Groter / Kleiner", "value": "size" },
            { "label": "Bold wit / Lichtgrijs", "value": "boldcolor" }
          ],
          "default": "color"
        },
        {
          "key": "dateFormat", "type": "choice", "section": "Weergave", "label": "labelDateFormat",
          "choices": [
            { "label": "12-5", "value": "date" },
            { "label": "Ma (afgekort)", "value": "short" },
            { "label": "Maandag (volledig)", "value": "full" }
          ],
          "default": "date"
        },
        {
          "key": "alignment", "type": "choice", "section": "Weergave", "label": "labelAlignment",
          "choices": [
            { "label": "Links", "value": "left" },
            { "label": "Rechts", "value": "right" }
          ],
          "default": "left"
        }
      ]
    }
  ]
}
